                <mxCell id="tree-title" value="&lt;b&gt;Hierarchie des conteneurs (composition de Nodes)&lt;/b&gt;" style="text;html=1;align=left;fontSize=14;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="100" y="780" width="500" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="tree" value="Stage&#xa;  +-- Scene&#xa;        +-- BorderPane (root)&#xa;              +-- CENTER : TabPane&#xa;              |     +-- Tab &quot;Boutons&quot;&#xa;              |     |     +-- SplitPane&#xa;              |     |           +-- ScrollPane &gt; VBox &gt; (blocs de demos)&#xa;              |     |           +-- VBox &gt; Label + TextArea (zone info)&#xa;              |     +-- Tab &quot;Saisie&quot; ... idem&#xa;              |     +-- ... (7 onglets au total)&#xa;              +-- BOTTOM : Label (barre d&#39;etat)" style="text;html=1;align=left;verticalAlign=top;fontFamily=monospace;fontSize=11;fillColor=#f8f8f8;strokeColor=#999;rounded=1;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="100" y="815" width="700" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="note1" value="&lt;b&gt;Methode pour modeliser une interface JavaFX :&lt;/b&gt;&#xa;&#xa;1. Identifier le &lt;b&gt;conteneur racine&lt;/b&gt; (BorderPane / VBox / GridPane...)&#xa;2. Decouper en zones logiques (haut, centre, bas, ...)&#xa;3. Pour chaque zone, choisir le bon &lt;b&gt;layout&lt;/b&gt; et les &lt;b&gt;controles&lt;/b&gt;&#xa;4. Annoter les composants : nom du widget JavaFX a utiliser&#xa;5. Reflechir aux &lt;b&gt;evenements&lt;/b&gt; (qui declenche quoi ?)&#xa;&#xa;&lt;b&gt;Doc :&lt;/b&gt; openjfx.io / Scene Builder pour prototyper visuellement." style="shape=note;size=14;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="820" y="810" width="500" height="150" as="geometry"/>
                </mxCell>
            </root>
