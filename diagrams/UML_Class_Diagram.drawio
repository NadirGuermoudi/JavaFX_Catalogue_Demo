                <mxCell id="comp1" value="*" style="endArrow=diamondThin;endFill=1;endSize=14;startArrow=none;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.206;entryY=1;entryDx=0;entryDy=0;entryPerimeter=0;" parent="1" source="m-info" target="m-cat-m" edge="1">
