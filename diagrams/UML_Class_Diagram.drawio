                <mxCell id="leg-title" value="&lt;b&gt;Legende UML&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;spacingLeft=6;rounded=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1050" width="200" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="leg-content" value="&lt;b&gt;-&lt;/b&gt; private &amp;nbsp;&amp;nbsp; &lt;b&gt;+&lt;/b&gt; public &amp;nbsp;&amp;nbsp; &lt;b&gt;#&lt;/b&gt; protected &amp;nbsp;&amp;nbsp; &lt;b&gt;&lt;u&gt;souligne&lt;/u&gt;&lt;/b&gt; = static&#xa;&lt;b&gt;&lt;i&gt;Italique&lt;/i&gt;&lt;/b&gt; = classe / methode abstraite&#xa;&lt;b&gt;Fleche pleine triangle blanc&lt;/b&gt; = heritage (extends)&#xa;&lt;b&gt;Losange noir&lt;/b&gt; = composition (le tout possede les parties)&#xa;&lt;b&gt;Fleche en pointille&lt;/b&gt; = dependance / utilisation (cree, lit, ecoute)&#xa;&lt;b&gt;Point noir&lt;/b&gt; = jonction (plusieurs sous-classes partagent une meme relation)" style="text;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;spacingLeft=6;spacingTop=4;rounded=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1080" width="600" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="note-mvc" value="&lt;b&gt;Pourquoi MVC ?&lt;/b&gt;&#xa;&#xa;&lt;b&gt;Modele&lt;/b&gt; : ne connait NI la vue NI le controleur. Il expose des donnees.&#xa;&lt;b&gt;Vue&lt;/b&gt; : connait les composants JavaFX mais NE GERE PAS les evenements metier.&#xa;&lt;b&gt;Controleur&lt;/b&gt; : connait la vue ET le modele. Il fait le pont entre les deux.&#xa;&#xa;&lt;b&gt;Avantage :&lt;/b&gt; on peut changer la vue (ex. FXML) sans toucher au modele." style="shape=note;size=14;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="900" y="1050" width="700" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="note-doc" value="&lt;b&gt;Pour aller plus loin :&lt;/b&gt;&#xa;Documentation JavaFX officielle : &lt;b&gt;https://openjfx.io/javadoc/21/&lt;/b&gt;&#xa;Tutoriel JavaFX : &lt;b&gt;https://openjfx.io/openjfx-docs/&lt;/b&gt;" style="shape=note;size=14;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1220" width="600" height="80" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
